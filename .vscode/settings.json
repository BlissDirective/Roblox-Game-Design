{
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "files.associations": {
    "*.luau": "luau",
    ".project.json": "jsonc",
    "*.project.json": "jsonc"
  },

  "editor.tabSize": 4,
  "editor.insertSpaces": false,
  "editor.detectIndentation": false,
  "editor.formatOnSave": true,
  "editor.rulers": [120],

  "[luau]": {
    "editor.defaultFormatter": "JohnnyMorganz.stylua",
    "editor.tabSize": 4,
    "editor.insertSpaces": false
  },
  "[lua]": {
    "editor.defaultFormatter": "JohnnyMorganz.stylua"
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "[markdown]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "files.trimTrailingWhitespace": false
  },

  "luau-lsp.sourcemap.enabled": true,
  "luau-lsp.sourcemap.autogenerate": true,
  "luau-lsp.sourcemap.rojoProjectFile": "default.project.json",
  "luau-lsp.types.roblox": true,
  "luau-lsp.completion.imports.enabled": true,
  "luau-lsp.diagnostics.strictDatamodelTypes": true,

  "stylua.searchParentDirectories": true,
  "selene.warnOnNoSelene": true
}
